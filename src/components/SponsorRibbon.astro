---
import { publicImage } from '../lib/publicImages';
import { withBase } from '../lib/url';

const sponsors = [
	{ name: 'DuPont', logo: 'dupont.svg', href: 'https://www.dupont.ca/' },
	{ name: 'HTS', logo: 'hts.svg', href: 'https://www.hts.com/' },
	{ name: 'CEED uOttawa', logo: 'ceed.svg', href: 'https://ceed-uottawa.ca/' },
	{
		name: 'Engineering Endowment Fund',
		logo: 'eef.svg',
		href: 'https://www.uottawa.ca/faculty-engineering/student-experience/funding-student-initiatives',
	},
	{ name: 'Rhystone', logo: 'rhystone.svg', href: 'https://www.rhystone.com/' },
	{ name: 'T-Motor', logo: 'tmotor.svg', href: 'https://store.tmotor.com/' },
	{ name: 'Ansys', logo: 'ansys.svg', href: 'https://www.ansys.com/' },
	{ name: 'Winghelper', logo: 'winghelper.svg', href: 'https://www.winghelper.com/default/' },
	{ name: 'MATLAB', logo: 'matlab.svg', href: 'https://www.mathworks.com/products/matlab.html' },
	{ name: 'SolidWorks', logo: 'solidworks.svg', href: 'https://www.solidworks.com/' },
];
---

<footer class="border-t-[3px] border-accent bg-surface px-6 pb-7 pt-9 md:px-10">
	<div class="mx-auto max-w-[1240px]">
		<div class="mb-4.5 flex flex-wrap items-baseline justify-between gap-4">
			<h6 class="m-0 text-accent-700">Our Partners</h6>
			<a href={withBase('/partner')} class="text-sm font-semibold text-accent no-underline hover:underline"
				>Want to sponsor us? &rarr;</a
			>
		</div>
		<div class="flex flex-wrap items-center gap-6">
			{
				sponsors.map((s) => (
					<a href={s.href} title={s.name} class="flex h-[56px] w-[130px] items-center justify-center">
						<img src={publicImage(`/images/sponsors/${s.logo}`).src} alt={`${s.name} logo`} class="max-h-full max-w-full" />
					</a>
				))
			}
		</div>
		<div
			class="mt-6 flex flex-wrap justify-between gap-2 border-t border-divider pt-4 text-xs text-neutral-600"
		>
			<p class="m-0">&copy; University of Ottawa Aeronautics Team</p>
			<p class="m-0">aeronautics@uottawa.ca</p>
		</div>
	</div>
</footer>
