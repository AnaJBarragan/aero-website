---
import { withBase } from '../lib/url';

interface Props {
	active?: string;
}

const { active = '' } = Astro.props;

const links = [
	{ key: 'home', label: 'Home', href: '/' },
	{ key: 'about', label: 'About Us', href: '/about' },
	{ key: 'team', label: 'Meet the Team', href: '/team' },
	{ key: 'competition', label: 'Competition', href: '/competition' },
	{ key: 'aircraft', label: 'Aircraft', href: '/aircraft' },
	{ key: 'gallery', label: 'Gallery', href: '/gallery' },
	{ key: 'contact', label: 'Contact Us', href: '/contact' },
];
---

<nav
	class="sticky top-0 z-50 flex items-center gap-7 border-b-2 border-divider bg-bg px-6 py-3 md:px-10"
>
	<a href={withBase('/')} class="mr-auto flex items-center gap-2.5 text-ink no-underline">
		<div
			class="flex h-9 w-9 flex-none items-center justify-center bg-accent font-heading text-sm font-bold text-white"
		>
			uOA
		</div>
		<span class="font-heading text-[17px] font-extrabold tracking-tight">uOAeronautics</span>
	</a>
	<div class="hidden flex-wrap items-center gap-7 md:flex">
		{
			links.map((link) => (
				<a
					href={withBase(link.href)}
					class:list={[
						'whitespace-nowrap border-b-[3px] pb-2 pt-1 font-heading text-sm no-underline',
						link.key === active
							? 'border-accent-700 font-extrabold text-accent-700'
							: 'border-transparent font-semibold text-ink',
					]}
				>
					{link.label}
				</a>
			))
		}
	</div>
	<details class="relative ml-auto md:hidden">
		<summary
			class="flex h-9 w-9 cursor-pointer list-none items-center justify-center border border-divider"
			aria-label="Open menu"
		>
			<svg width="18" height="14" viewBox="0 0 18 14" fill="none">
				<path d="M0 1H18M0 7H18M0 13H18" stroke="currentColor" stroke-width="1.5" />
			</svg>
		</summary>
		<div
			class="absolute right-0 top-11 flex w-56 flex-col gap-1 border border-divider bg-bg p-3 shadow-lg"
		>
			{
				links.map((link) => (
					<a
						href={withBase(link.href)}
						class:list={[
							'px-2 py-2 font-heading text-sm no-underline',
							link.key === active ? 'font-extrabold text-accent-700' : 'font-semibold text-ink',
						]}
					>
						{link.label}
					</a>
				))
			}
		</div>
	</details>
</nav>
