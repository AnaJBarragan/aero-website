---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import SponsorRibbon from '../components/SponsorRibbon.astro';
import { withBase } from '../lib/url';

import WideWorkshop from '@public/images/site/wide-workshop.webp';
import WinterTeamPhoto from '@public/images/site/winter-team-photo.webp';

const process = [
	{
		num: '01',
		title: 'Design',
		copy: 'We define mission requirements and iterate through CAD, structural analysis and aerodynamic simulation.',
	},
	{
		num: '02',
		title: 'Build',
		copy: 'Our team fabricates airframes, composite and 3D-printed parts and electronics in our JMTS workshop.',
	},
	{
		num: '03',
		title: 'Test',
		copy: 'Ground testing and instrumented flight tests validate every design decision before competition.',
	},
	{ num: '04', title: 'Fly', copy: 'We fly at SAE Aero Design East and at local test flights throughout the year.' },
];
---

<Layout title="About Us — uOAeronautics">
	<NavBar active="about" />

	<section class="relative flex min-h-[320px] items-center overflow-hidden">
		<div class="absolute inset-0 grayscale">
			<img src={WideWorkshop.src} alt="Our workshop" class="h-full w-full object-cover" />
		</div>
		<div class="absolute inset-0" style="background:linear-gradient(100deg, rgba(32,30,29,.9), rgba(32,30,29,.5))">
		</div>
		<div class="absolute right-5 top-5 z-10 h-4 w-4 bg-accent"></div>
		<div class="relative mx-auto w-full max-w-[1240px] px-6 py-10 text-white md:px-10">
			<h6 class="text-accent-300">About Us</h6>
			<h1 class="m-0 max-w-[20ch] text-white">Who we are, and what we do</h1>
		</div>
	</section>

	<section class="mx-auto max-w-[1240px] px-6 py-18 md:px-10">
		<h6 class="text-accent">Our Mission</h6>
		<h2 class="mb-5 max-w-[24ch]">We give real world, practical experience to uOttawa students</h2>
		<p class="max-w-[70ch] text-[17px] text-ink/80">
			uOAeronautics is a University of Ottawa JMTS (John McEntyre Team Space) team that designs,
			builds and flies RC aircraft for the <a href="https://www.saeaerodesign.com/" class="text-accent">SAE Aero Design</a>
			competition. Students choose, based on their abilities and interests, one of our two
			subteams — Micro or Advanced — and work across disciplines including aerodynamics,
			structures, propulsion, avionics and manufacturing to bring a competition aircraft from CAD
			model to the flight line.
		</p>

		<div class="my-10 grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-6">
			<div class="border-t-[3px] border-accent pt-4">
				<h3 class="mb-2">Engineered to Fly</h3>
				<p class="m-0 text-sm text-ink/60">Every design decision is validated through analysis, simulation and real flight testing.</p>
			</div>
			<div class="border-t-[3px] border-accent pt-4">
				<h3 class="mb-2">Built by Students</h3>
				<p class="m-0 text-sm text-ink/60">The team is run and staffed entirely by uOttawa students, across every subteam.</p>
			</div>
			<div class="border-t-[3px] border-accent pt-4">
				<h3 class="mb-2">Two Competing Classes</h3>
				<p class="m-0 text-sm text-ink/60">We build a Micro Class and an Advanced Class aircraft every year for SAE Aero Design.</p>
			</div>
		</div>

		<div class="grid grid-cols-1 items-center gap-10 md:grid-cols-[1.3fr_1fr]">
			<div class="grayscale">
				<img src={WinterTeamPhoto.src} alt="Team group photo before a test-flight" class="aspect-video w-full object-cover" />
			</div>
			<div>
				<h3 class="mb-2.5">Meet the people behind the airframe</h3>
				<p class="mb-5 text-[15px] text-ink/60">
					Leads and members across every subteam — from the Micro and Advanced aircraft leads to
					electronics, design and CFD.
				</p>
				<a href={withBase('/team')} class="btn btn-primary">Click here to meet the team &rarr;</a>
			</div>
		</div>
	</section>

	<hr class="mx-auto max-w-[1240px] border-divider" />

	<section class="mx-auto max-w-[1240px] px-6 pb-18 pt-14 md:px-10">
		<h6 class="text-accent">What We Do</h6>
		<h2 class="mb-5 max-w-[30ch]">Design, make and fly remote controlled aircraft to compete at SAE Aero Design</h2>
		<p class="mb-2 max-w-[70ch] text-[17px] text-ink/80">
			Learn about aerodynamics and experiment with airfoils and avionics as you develop two
			competing prototypes. Optimize lift with our STOL Micro aircraft, or work on autonomous
			hybrid VTOL/STOL flight with our Advanced aircraft. Every part of both aircraft is our own
			work, from the first CAD sketch to the final flight line.
		</p>

		<div class="my-8">
			{
				process.map((p) => (
					<div class="grid grid-cols-[64px_1fr] gap-5 border-t-2 border-divider py-5">
						<p class="m-0 flex items-center gap-2 font-heading text-[15px] font-extrabold text-accent">
							<span class="h-2 w-2 flex-none bg-accent" />
							{p.num}
						</p>
						<div>
							<h4 class="mb-1.5">{p.title}</h4>
							<p class="m-0 max-w-[60ch] text-[14.5px] text-ink/60">{p.copy}</p>
						</div>
					</div>
				))
			}
		</div>

		<div class="flex flex-wrap gap-3.5">
			<a href={withBase('/competition')} class="btn btn-primary">See the Competition &rarr;</a>
			<a href={withBase('/gallery')} class="btn btn-secondary">Construction &amp; Testing Photos</a>
		</div>
	</section>

	<SponsorRibbon />
</Layout>
