---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import SponsorRibbon from '../components/SponsorRibbon.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';

const values = [
	{
		title: 'Engineered to Fly',
		copy: 'Every rivet, spar and control surface is justified by analysis and test, not guesswork.',
	},
	{
		title: 'Built by Students',
		copy: 'From freshmen to grad students, every subteam is run and staffed entirely by uOttawa students.',
	},
	{
		title: 'Grounded in Rigor',
		copy: 'Data-driven iteration from CAD model to wind tunnel to the competition tarmac.',
	},
];

const process = [
	{
		num: '01',
		title: 'Design',
		copy: 'We define mission requirements and iterate through CAD, structural analysis and aerodynamic simulation.',
	},
	{
		num: '02',
		title: 'Build',
		copy: 'Our manufacturing team fabricates airframes, composite parts and electronics entirely in-house.',
	},
	{
		num: '03',
		title: 'Test',
		copy: 'Ground testing, structural proofing and instrumented flight tests validate every design decision.',
	},
	{ num: '04', title: 'Fly', copy: 'We fly at SAE Aero Design and at local test flights throughout the year.' },
];
---

<Layout title="About Us — uOAeronautics">
	<NavBar active="about" />

	<section class="relative flex min-h-[320px] items-center overflow-hidden">
		<div class="absolute inset-0 grayscale">
			<ImagePlaceholder label="Drop workshop/team photo" class="h-full w-full" />
		</div>
		<div class="absolute inset-0" style="background:linear-gradient(100deg, rgba(32,30,29,.9), rgba(32,30,29,.5))">
		</div>
		<div class="absolute right-5 top-5 z-10 h-4 w-4 bg-accent"></div>
		<div class="relative mx-auto w-full max-w-[1240px] px-6 py-10 text-white md:px-10">
			<h6 class="text-accent-300">About Us</h6>
			<h1 class="m-0 max-w-[20ch] text-white">Who we are, and what we do</h1>
		</div>
	</section>

	<section class="mx-auto max-w-[1240px] px-6 py-18 md:px-10">
		<h6 class="text-accent">Who We Are</h6>
		<h2 class="mb-5 max-w-[20ch]">A student team engineering flight from the ground up</h2>
		<p class="max-w-[70ch] text-[17px] text-ink/80">
			uOAeronautics is the University of Ottawa's student-run aircraft design team, founded by a
			small group of engineering students who wanted to take flight theory out of the classroom
			and into a hangar. What started as a handful of students sketching wing profiles between
			classes has grown into a full multidisciplinary program spanning aerodynamics, structures,
			propulsion, avionics and manufacturing. Our goal is simple: give uOttawa students the chance
			to design, build, test and fly a real aircraft every year, and to represent the university at
			SAE Aero Design with a competitive, reliable airframe.
		</p>

		<div class="my-10 grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-6">
			{
				values.map((v) => (
					<div class="border-t-[3px] border-accent pt-4">
						<h3 class="mb-2">{v.title}</h3>
						<p class="m-0 text-sm text-ink/60">{v.copy}</p>
					</div>
				))
			}
		</div>

		<div class="grid grid-cols-1 items-center gap-10 md:grid-cols-[1.3fr_1fr]">
			<div class="grayscale">
				<ImagePlaceholder label="Team group photo" class="aspect-video w-full" />
			</div>
			<div>
				<h3 class="mb-2.5">Meet the people behind the airframe</h3>
				<p class="mb-5 text-[15px] text-ink/60">
					Leads and members across every subteam — aerodynamics, structures, propulsion, avionics
					and manufacturing.
				</p>
				<a href="/team" class="btn btn-primary">Click here to meet the team &rarr;</a>
			</div>
		</div>
	</section>

	<hr class="mx-auto max-w-[1240px] border-divider" />

	<section class="mx-auto max-w-[1240px] px-6 pb-18 pt-14 md:px-10">
		<h6 class="text-accent">What We Do</h6>
		<h2 class="mb-5 max-w-[26ch]">We design, build, test and fly our own aircraft</h2>
		<p class="mb-2 max-w-[70ch] text-[17px] text-ink/80">
			Each year our team competes in SAE Aero Design, an international collegiate competition that
			challenges student teams to design and manufacture a radio-controlled aircraft to a strict
			set of mission requirements. From the first CAD sketch to the final flight line, every part
			of the aircraft is our own work.
		</p>

		<div class="my-8">
			{
				process.map((p) => (
					<div class="grid grid-cols-[64px_1fr] gap-5 border-t-2 border-divider py-5">
						<p class="m-0 flex items-center gap-2 font-heading text-[15px] font-extrabold text-accent">
							<span class="h-2 w-2 flex-none bg-accent" />
							{p.num}
						</p>
						<div>
							<h4 class="mb-1.5">{p.title}</h4>
							<p class="m-0 max-w-[60ch] text-[14.5px] text-ink/60">{p.copy}</p>
						</div>
					</div>
				))
			}
		</div>

		<div class="flex flex-wrap gap-3.5">
			<a href="/competition" class="btn btn-primary">See the Competition &rarr;</a>
			<a href="/gallery" class="btn btn-secondary">Construction &amp; Testing Photos</a>
		</div>
	</section>

	<SponsorRibbon />
</Layout>
