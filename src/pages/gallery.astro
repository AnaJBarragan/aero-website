---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import SponsorRibbon from '../components/SponsorRibbon.astro';

function toCaption(filename: string) {
	const base = filename.replace(/\.[^.]+$/, '').replace(/-/g, ' ');
	return base.charAt(0).toUpperCase() + base.slice(1);
}

function loadAlbum(dir: string, urlBase: string) {
	const full = path.resolve('public/images', dir);
	return fs
		.readdirSync(full)
		.sort()
		.map((file) => ({ src: `${urlBase}/${file}`, caption: toCaption(file) }));
}

const albumDefs = [
	{ name: 'Starling — Advanced Class 2026', dir: 'aircraft/2026-advanced', urlBase: '/images/aircraft/2026-advanced' },
	{ name: 'SG32C — Micro Class 2026', dir: 'aircraft/2026-micro', urlBase: '/images/aircraft/2026-micro' },
	{ name: 'Longshot — Advanced Class 2025', dir: 'aircraft/2025-advanced', urlBase: '/images/aircraft/2025-advanced' },
	{ name: 'UOAN-M25 — Micro Class 2025', dir: 'aircraft/2025-micro', urlBase: '/images/aircraft/2025-micro' },
	{ name: 'Introductory Meeting & Micro Test Flight', dir: 'gallery/2025-09-26', urlBase: '/images/gallery/2025-09-26' },
	{ name: 'Recruitment — Club Fair', dir: 'gallery/2025-09-02', urlBase: '/images/gallery/2025-09-02' },
	{ name: 'Recruitment — New Semester', dir: 'gallery/2025-09-01', urlBase: '/images/gallery/2025-09-01' },
	{ name: 'More Flight Tests', dir: 'gallery/2025-07-27', urlBase: '/images/gallery/2025-07-27' },
	{ name: 'First Flight Test After Competition', dir: 'gallery/2025-07-21', urlBase: '/images/gallery/2025-07-21' },
];

const albums = albumDefs.map((a, i) => ({
	...a,
	bg: i % 2 === 0 ? 'bg-bg' : 'bg-surface',
	photos: loadAlbum(a.dir, a.urlBase),
}));

const collage = [
	'/images/aircraft/2026-advanced/starling-on-a-stand-at-the-test-field.jpg',
	'/images/aircraft/2026-micro/sg32c-ready-for-takeoff.jpg',
	'/images/aircraft/2025-advanced/the-aircraft-having-just-taken-off.jpg',
	'/images/aircraft/2025-micro/the-aircraft-ready-to-fly-on-the-competition-tarmac.jpg',
	'/images/gallery/2025-09-26/the-plane-in-flight-as-seen-from-the-side.jpg',
	'/images/gallery/2025-07-27/the-sea-duck-flying-close-to-the-ground.jpg',
];

const highlights = [
	{ src: '/images/aircraft/2026-micro/kaden-being-happy-with-the-current-state-of-sg32c.jpg', caption: 'Kaden with SG32C' },
	{ src: '/images/aircraft/2026-advanced/testing-the-vtol-functionality-of-starling.jpg', caption: 'Testing Starling\'s VTOL functionality' },
	{ src: '/images/site/adv-2025-longshot-glamour.webp', caption: 'Project Longshot' },
	{ src: '/images/aircraft/2026-micro/showing-off-the-lightweight-carbon-fiber-propellors.jpg', caption: 'Carbon fibre propellers' },
];
---

<Layout title="Gallery — uOAeronautics">
	<NavBar active="gallery" />

	<section class="relative flex min-h-[340px] items-center overflow-hidden">
		<div class="absolute inset-0 grid grid-cols-6 grid-rows-2 grayscale">
			{collage.map((src) => <img src={src} alt="" class="h-full w-full object-cover" />)}
		</div>
		<div class="absolute inset-0" style="background:linear-gradient(100deg, rgba(32,30,29,.92), rgba(32,30,29,.55))">
		</div>
		<div class="absolute right-5 top-5 z-10 h-4 w-4 bg-accent"></div>
		<div class="relative mx-auto w-full max-w-[1240px] px-6 py-10 text-white md:px-10">
			<h6 class="text-accent-300">Gallery</h6>
			<h1 class="m-0 max-w-[20ch] text-white">Design, build, test and fly — in photos</h1>
		</div>
	</section>

	<section class="mx-auto max-w-[1240px] px-6 pb-2 pt-10 md:px-10">
		<p class="max-w-[64ch] text-base text-ink/60">
			Highlights from the season, plus every album from our workshop to the flight line.
		</p>
	</section>

	<section class="mx-auto max-w-[1240px] px-6 pb-16 pt-4 md:px-10">
		<h6 class="text-accent">Highlights</h6>
		<h2 class="mb-6">A few favourites from this season</h2>
		<div class="grid grid-cols-2 gap-4 md:grid-cols-4">
			{
				highlights.map((h) => (
					<div class="grayscale">
						<img src={h.src} alt={h.caption} class="aspect-square w-full object-cover" />
					</div>
				))
			}
		</div>
	</section>

	{
		albums.map((album) => (
			<section class:list={[album.bg, 'px-6 py-12 md:px-10']}>
				<div class="mx-auto max-w-[1240px]">
					<div class="mb-4.5 flex flex-wrap items-baseline justify-between gap-4">
						<h2 class="m-0">{album.name}</h2>
						<span class="tag tag-outline">{album.photos.length} photos</span>
					</div>
					<div class="grid grid-cols-[repeat(auto-fill,minmax(180px,1fr))] gap-3">
						{album.photos.map((p) => (
							<div class="grayscale">
								<img src={p.src} alt={p.caption} title={p.caption} class="aspect-4/3 w-full object-cover" />
							</div>
						))}
					</div>
				</div>
			</section>
		))
	}

	<SponsorRibbon />
</Layout>
