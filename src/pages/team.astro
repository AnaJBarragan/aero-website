---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import SponsorRibbon from '../components/SponsorRibbon.astro';
import { publicImage } from '../lib/publicImages';

import WinterTeamPhoto from '@public/images/site/winter-team-photo.webp';

const rawMembers = [
	{
		name: 'Ana J. Barragan',
		role: 'Team Captain',
		subteam: 'Leadership',
		photo: 'ana-j-barragan.webp',
		email: 'abarr168@uottawa.ca',
		linkedin: 'https://linkedin.com/in/ana-j-barragan',
		bio: 'Coordinates every subteam, sets project milestones, and represents uOAeronautics at competition.',
	},
	{
		name: 'Zaid Lateef',
		role: 'Pilot',
		subteam: 'Flight',
		photo: 'zaid-lateef.webp',
		email: 'zlate012@uottawa.ca',
		linkedin: 'https://www.linkedin.com/in/zaid-lateef-070306302',
		bio: 'Flies every test and competition mission for both the Micro and Advanced class aircraft.',
	},
	{
		name: 'Stelle Zhao',
		role: 'Advanced Electronics Lead',
		subteam: 'Advanced',
		photo: 'stelle-zhao.webp',
		email: 'czhao052@uottawa.ca',
		linkedin: '',
		bio: 'Leads the avionics, wiring and ground control systems for the Advanced Class aircraft.',
	},
	{
		name: 'Benjamin Beck',
		role: 'Little bit of this little bit of that.',
		subteam: 'General',
		photo: 'benjamin-beck.webp',
		email: 'bbeck023@uottawa.ca',
		linkedin: 'https://www.linkedin.com/in/benjamin-vj-beck',
		bio: 'Pitches in wherever the team needs a hand, from design to manufacturing.',
	},
	{
		name: 'Kaden Graham',
		role: 'Micro Team Lead',
		subteam: 'Micro',
		photo: 'kaden-graham.webp',
		email: 'kgrah049@uottawa.ca',
		linkedin: 'https://www.linkedin.com/in/kadengraham050704',
		bio: 'Leads the Micro Class subteam, from airframe design through to competition day.',
	},
	{
		name: 'Finley St-Denis',
		role: 'Micro & Media',
		subteam: 'Micro',
		photo: 'finley-st-denis.webp',
		email: 'fstde090@uottawa.ca',
		linkedin: 'https://www.linkedin.com/in/finley-st-denis/',
		bio: 'Works on the Micro Class aircraft and documents the team through photo and video.',
	},
	{
		name: 'Nathan Beaulieu',
		role: 'Design',
		subteam: 'Design',
		photo: 'nathan-beaulieu.webp',
		email: 'nbeau092@uottawa.ca',
		linkedin: '',
		bio: 'Works on CAD design for the team’s aircraft.',
	},
	{
		name: 'Maya',
		role: 'Programmer and Electronics',
		subteam: 'Electronics',
		photo: 'maya.webp',
		email: 'ydier065@uottawa.ca',
		linkedin: '',
		blog: 'https://dierolf.ca',
		bio: 'Builds the flight software and electronics that keep the aircraft flying true.',
	},
	{
		name: 'Adonai Tshibasu',
		role: 'Micro Fuselage Lead',
		subteam: 'Micro',
		photo: 'adonai-tshibasu.webp',
		email: 'atshi095@uottawa.ca',
		linkedin: 'https://www.linkedin.com/in/adonai-tshibasu13',
		bio: 'Leads fuselage design and manufacturing for the Micro Class aircraft.',
	},
	{
		name: 'Taha El Faghloumi',
		role: 'Micro CFD Lead',
		subteam: 'Micro',
		photo: 'taha-el-faghloumi.webp',
		email: 'telfa036@uottawa.ca',
		linkedin: 'https://www.linkedin.com/in/taha-el-faghloumi-586795301',
		bio: 'Runs CFD simulations to validate airfoil and wing performance for the Micro Class aircraft.',
	},
];

const members = rawMembers.map((m, i) => {
	const id = `member-${m.name.toLowerCase().replace(/[^a-z]+/g, '-').replace(/(^-|-$)/g, '')}`;
	return {
		...m,
		id,
		anchor: `#${id}`,
		mailto: `mailto:${m.email}`,
		photoSrc: publicImage(`/images/team/${m.photo}`).src,
		reverse: i % 2 !== 0,
		bg: i % 2 === 0 ? 'bg-bg' : 'bg-surface',
	};
});
---

<Layout title="Meet the Team — uOAeronautics">
	<NavBar active="team" />

	<section class="relative flex min-h-[300px] items-center overflow-hidden">
		<div class="absolute inset-0 grayscale">
			<img src={WinterTeamPhoto.src} alt="Team photo before a test-flight" class="h-full w-full object-cover" />
		</div>
		<div class="absolute inset-0" style="background:linear-gradient(100deg, rgba(32,30,29,.9), rgba(32,30,29,.5))">
		</div>
		<div class="absolute right-5 top-5 z-10 h-4 w-4 bg-accent"></div>
		<div class="relative mx-auto w-full max-w-[1240px] px-6 py-10 text-white md:px-10">
			<h6 class="text-accent-300">Meet the Team</h6>
			<h1 class="m-0 max-w-[20ch] text-white">The students behind the airframe</h1>
		</div>
	</section>

	<section class="mx-auto max-w-[1240px] px-6 pb-4 pt-10 md:px-10">
		<p class="max-w-[64ch] text-base text-ink/60">Click a face to jump straight to their profile below.</p>
	</section>

	<section class="mx-auto max-w-[1240px] px-6 pb-16 pt-2 md:px-10">
		<div class="grid grid-cols-[repeat(auto-fill,minmax(120px,1fr))] gap-x-4 gap-y-6">
			{
				members.map((m) => (
					<a href={m.anchor} class="block text-center text-inherit no-underline">
						<div class="aspect-square w-full overflow-hidden rounded-full grayscale">
							<img src={m.photoSrc} alt={m.name} class="h-full w-full object-cover" />
						</div>
						<p class="mb-0.5 mt-2.5 font-heading text-[13px] font-bold">{m.name}</p>
						<p class="m-0 text-[11px] text-ink/60">{m.role}</p>
					</a>
				))
			}
		</div>
	</section>

	<hr class="mx-auto max-w-[1240px] border-divider" />

	{
		members.map((m) => (
			<section id={m.id} class:list={[m.bg, 'scroll-mt-20 px-6 py-14 md:px-10']}>
				<div
					class:list={[
						'mx-auto flex max-w-[1240px] flex-wrap items-center gap-12',
						m.reverse ? 'flex-row-reverse' : 'flex-row',
					]}
				>
					<div class="grayscale w-full min-w-[240px] max-w-[380px] flex-1 basis-[320px]">
						<img src={m.photoSrc} alt={m.name} class="aspect-[3/4] w-full object-cover" />
					</div>
					<div class="min-w-[280px] flex-[2_1_420px]">
						<h6 class="text-accent">{m.subteam}</h6>
						<h3 class="mb-1">{m.name}</h3>
						<p class="mb-3.5 font-semibold text-ink/70">{m.role}</p>
						<p class="mb-4.5 max-w-[56ch] text-[15px] text-ink/60">{m.bio}</p>
						<div class="flex flex-wrap items-center gap-4">
							<a href={m.mailto} class="text-[13.5px] font-semibold text-accent">
								{m.email}
							</a>
							{m.linkedin && (
								<a href={m.linkedin} class="text-[13.5px] font-semibold text-accent">
									LinkedIn &nearr;
								</a>
							)}
							{m.blog && (
								<a href={m.blog} class="text-[13.5px] font-semibold text-accent">
									Blog &nearr;
								</a>
							)}
						</div>
					</div>
				</div>
			</section>
		))
	}

	<section class="mx-auto max-w-[1240px] px-6 py-8 md:px-10">
		<p class="m-0 text-xs text-ink/50">
			Avatars created and rendered with <a href="https://github.com/datkat21/mii-creator" class="text-accent">Mii Creator</a>.
		</p>
	</section>

	<SponsorRibbon />
</Layout>
