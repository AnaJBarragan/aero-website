---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import SponsorRibbon from '../components/SponsorRibbon.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';

const leads = [
	{ name: 'Alex Tremblay', role: 'Team Captain', subteam: 'Leadership', year: '4th Year Mechanical Engineering' },
	{
		name: 'Morgan Chen',
		role: 'Aerodynamics Lead',
		subteam: 'Aerodynamics',
		year: '4th Year Mechanical Engineering',
	},
	{ name: 'Jordan Singh', role: 'Structures Lead', subteam: 'Structures', year: '3rd Year Mechanical Engineering' },
	{ name: 'Taylor Nguyen', role: 'Propulsion Lead', subteam: 'Propulsion', year: '4th Year Electrical Engineering' },
	{
		name: 'Casey Dubois',
		role: 'Avionics & Manufacturing Lead',
		subteam: 'Avionics',
		year: '3rd Year Software Engineering',
	},
];

const memberNames = [
	'Riley Martin',
	'Sam Gagnon',
	'Jamie Roy',
	'Drew Bouchard',
	'Charlie Leblanc',
	'Reese Fortin',
	'Quinn Levesque',
	'Avery Cormier',
	'Rowan Pelletier',
	'Skyler Belanger',
	'Emerson Girard',
	'Peyton Lavoie',
	'Dakota Morin',
	'Finley Boucher',
	'Blake Ouellet',
];
const subteams = ['Aerodynamics', 'Structures', 'Propulsion', 'Avionics', 'Manufacturing'];
const bios: Record<string, string> = {
	Leadership: 'Coordinates every subteam, sets project milestones, and represents uOAeronautics at competition.',
	Aerodynamics: 'Runs airfoil selection, stability analysis and aerodynamic simulation for each new airframe.',
	Structures: 'Designs and validates the wing, fuselage and mounting structures for strength and weight.',
	Propulsion: 'Selects and tests motors, propellers and battery systems for maximum thrust efficiency.',
	Avionics: 'Builds the flight electronics, telemetry and control systems that keep the aircraft flying true.',
	Manufacturing: 'Fabricates composite and CNC parts and leads assembly of the finished aircraft.',
};
const years = ['1st Year', '2nd Year', '3rd Year', '4th Year'];
const programs = ['Mechanical Engineering', 'Aerospace Engineering', 'Electrical Engineering', 'Software Engineering'];

const memberList = memberNames.map((name, i) => ({
	name,
	role: 'Team Member',
	subteam: subteams[i % subteams.length],
	year: `${years[i % years.length]} ${programs[i % programs.length]}`,
}));

const members = leads.concat(memberList).map((m, i) => {
	const id = `member-${m.name.toLowerCase().replace(/[^a-z]+/g, '-').replace(/(^-|-$)/g, '')}`;
	const [first, last] = m.name.split(' ');
	return {
		id,
		anchor: `#${id}`,
		name: m.name,
		role: m.role,
		subteam: m.subteam,
		yearInfo: m.year,
		bio: bios[m.subteam],
		email: `${first.toLowerCase()}.${last.toLowerCase()}@uottawa.ca`,
		mailto: `mailto:${first.toLowerCase()}.${last.toLowerCase()}@uottawa.ca`,
		reverse: i % 2 !== 0,
		bg: i % 2 === 0 ? 'bg-bg' : 'bg-surface',
	};
});
---

<Layout title="Meet the Team — uOAeronautics">
	<NavBar active="team" />

	<section class="relative flex min-h-[300px] items-center overflow-hidden">
		<div class="absolute inset-0 grayscale">
			<ImagePlaceholder label="Drop team group photo" class="h-full w-full" />
		</div>
		<div class="absolute inset-0" style="background:linear-gradient(100deg, rgba(32,30,29,.9), rgba(32,30,29,.5))">
		</div>
		<div class="absolute right-5 top-5 z-10 h-4 w-4 bg-accent"></div>
		<div class="relative mx-auto w-full max-w-[1240px] px-6 py-10 text-white md:px-10">
			<h6 class="text-accent-300">Meet the Team</h6>
			<h1 class="m-0 max-w-[20ch] text-white">Twenty students, one aircraft</h1>
		</div>
	</section>

	<section class="mx-auto max-w-[1240px] px-6 pb-4 pt-10 md:px-10">
		<p class="max-w-[64ch] text-base text-ink/60">Click a face to jump straight to their profile below.</p>
	</section>

	<section class="mx-auto max-w-[1240px] px-6 pb-16 pt-2 md:px-10">
		<div class="grid grid-cols-[repeat(auto-fill,minmax(120px,1fr))] gap-x-4 gap-y-6">
			{
				members.map((m) => (
					<a href={m.anchor} class="block text-center text-inherit no-underline">
						<div class="aspect-square w-full overflow-hidden rounded-full grayscale">
							<ImagePlaceholder label="Headshot" shape="circle" class="h-full w-full" />
						</div>
						<p class="mb-0.5 mt-2.5 font-heading text-[13px] font-bold">{m.name}</p>
						<p class="m-0 text-[11px] text-ink/60">{m.role}</p>
					</a>
				))
			}
		</div>
	</section>

	<hr class="mx-auto max-w-[1240px] border-divider" />

	{
		members.map((m) => (
			<section id={m.id} class:list={[m.bg, 'scroll-mt-20 px-6 py-14 md:px-10']}>
				<div
					class:list={[
						'mx-auto flex max-w-[1240px] flex-wrap items-center gap-12',
						m.reverse ? 'flex-row-reverse' : 'flex-row',
					]}
				>
					<div class="grayscale w-full min-w-[240px] max-w-[380px] flex-1 basis-[320px]">
						<ImagePlaceholder label={`${m.name} photo`} class="aspect-[3/4] w-full" />
					</div>
					<div class="min-w-[280px] flex-[2_1_420px]">
						<h6 class="text-accent">{m.subteam}</h6>
						<h3 class="mb-1">{m.name}</h3>
						<p class="mb-3.5 font-semibold text-ink/70">
							{m.role} &middot; {m.yearInfo}
						</p>
						<p class="mb-4.5 max-w-[56ch] text-[15px] text-ink/60">{m.bio}</p>
						<a href={m.mailto} class="text-[13.5px] font-semibold text-accent">
							{m.email}
						</a>
					</div>
				</div>
			</section>
		))
	}

	<SponsorRibbon />
</Layout>
