---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import SponsorRibbon from '../components/SponsorRibbon.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import ContactForm from '../components/ContactForm';
---

<Layout title="Contact Us — uOAeronautics">
	<NavBar active="contact" />

	<section class="mx-auto max-w-[1240px] px-6 pb-6 pt-16 md:px-10">
		<h6 class="text-accent">Contact Us</h6>
		<h1 class="mb-4 max-w-[22ch]">Want to reach out, or join the team?</h1>
		<p class="mb-2.5 max-w-[64ch] text-[17px] text-ink/60">
			Whether you have a question, want to get involved, or just want to say hello — we would love
			to hear from you. We recruit new members every fall and winter term.
		</p>
		<p class="m-0 text-base font-bold">
			<a href="mailto:aeronautics@uottawa.ca">aeronautics@uottawa.ca</a>
		</p>
	</section>

	<section class="mx-auto max-w-[1240px] px-6 pb-20 pt-2 md:px-10">
		<div class="grid grid-cols-1 items-start gap-14 md:grid-cols-[0.9fr_1.1fr]">
			<div class="grayscale">
				<ImagePlaceholder label="Team photo" class="aspect-4/5 w-full" />
			</div>
			<ContactForm client:load />
		</div>
	</section>

	<SponsorRibbon />
</Layout>
