---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import SponsorRibbon from '../components/SponsorRibbon.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';

const categories = [
	{
		tag: 'ADVANCED',
		title: 'Advanced Class',
		copy: 'The most technically demanding class, open to teams of any experience level, with the highest payload and performance targets.',
		focus: 'Payload capacity · structural efficiency',
	},
	{
		tag: 'REGULAR',
		title: 'Regular Class',
		copy: 'A balanced class for teams building foundational design and manufacturing experience with moderate mission complexity.',
		focus: 'Payload-to-weight ratio',
	},
	{
		tag: 'MICRO',
		title: 'Micro Class',
		copy: 'The smallest airframes on the field, judged on compact, efficient design within tight size and weight limits.',
		focus: 'Size & weight constraints',
	},
];

const criteria = [
	{
		name: 'Technical Design Report',
		desc: 'A written report documenting the design process, analysis and testing behind the aircraft.',
		weight: 'High',
	},
	{
		name: 'Oral Presentation',
		desc: 'A design review presented live to a panel of industry and academic judges.',
		weight: 'Medium',
	},
	{
		name: 'Ground / Technical Inspection',
		desc: 'Verifies the aircraft meets structural, electrical and safety requirements before flight.',
		weight: 'Pass / fail',
	},
	{
		name: 'Flight Mission Score',
		desc: 'Scored flights measuring payload carried, mission time and reliability against the class formula.',
		weight: 'High',
	},
	{
		name: 'Payload Efficiency',
		desc: 'Ratio of payload delivered to aircraft empty weight — rewards lean, purposeful design.',
		weight: 'Medium',
	},
];
---

<Layout title="Competition — uOAeronautics">
	<NavBar active="competition" />

	<section class="relative flex min-h-[300px] items-center overflow-hidden">
		<div class="absolute inset-0 grayscale">
			<ImagePlaceholder label="Drop competition flight-line photo" class="h-full w-full" />
		</div>
		<div class="absolute inset-0" style="background:linear-gradient(100deg, rgba(32,30,29,.9), rgba(32,30,29,.5))">
		</div>
		<div class="absolute right-5 top-5 z-10 h-4 w-4 bg-accent"></div>
		<div class="relative mx-auto w-full max-w-[1240px] px-6 py-10 text-white md:px-10">
			<h6 class="text-accent-300">SAE Aero Design</h6>
			<h1 class="m-0 max-w-[20ch] text-white">The Competition</h1>
		</div>
	</section>

	<section class="mx-auto max-w-[1240px] px-6 pb-4 pt-16 md:px-10">
		<h6 class="text-accent">Overview</h6>
		<h2 class="mb-4 max-w-[26ch]">A season-long design, build and fly challenge</h2>
		<p class="max-w-[72ch] text-[17px] text-ink/80">
			SAE Aero Design is an international collegiate competition where student teams design, build
			and fly a radio-controlled aircraft to a strict set of mission rules published each year.
			Teams are scored across three pillars: a written technical design report, an oral design
			presentation to a panel of industry judges, and flight performance measured against each
			class's scoring formula. It rewards the same engineering discipline used in industry: a
			documented design process, thorough analysis, and a machine that actually performs on the
			day.
		</p>
	</section>

	<section class="mx-auto max-w-[1240px] px-6 pb-16 pt-4 md:px-10">
		<h6 class="text-accent">Categories</h6>
		<h2 class="mb-7">The three competition classes</h2>
		<div class="grid grid-cols-[repeat(auto-fit,minmax(260px,1fr))] gap-6">
			{
				categories.map((c) => (
					<div class="card gap-3 p-6 shadow-sm">
						<span class="tag tag-accent self-start">{c.tag}</span>
						<h3 class="text-xl">{c.title}</h3>
						<p class="m-0 flex-1 text-[13px] opacity-80">{c.copy}</p>
						<p class="mt-2 flex items-center gap-1.5 text-[11px] text-ink/50">{c.focus}</p>
					</div>
				))
			}
		</div>
	</section>

	<section class="mx-auto max-w-[1240px] px-6 pb-18 pt-4 md:px-10">
		<h6 class="text-accent">Judging Breakdown</h6>
		<h2 class="mb-6">Key criteria per category</h2>
		<div class="overflow-x-auto">
			<table class="table-modernist">
				<thead>
					<tr>
						<th>Criteria</th>
						<th>What it measures</th>
						<th>Typical weight</th>
					</tr>
				</thead>
				<tbody>
					{
						criteria.map((row) => (
							<tr>
								<td class="font-heading font-bold">
									<span class="mr-2 inline-block h-2 w-2 align-middle bg-accent" />
									{row.name}
								</td>
								<td>{row.desc}</td>
								<td>{row.weight}</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>
	</section>

	<SponsorRibbon />
</Layout>
