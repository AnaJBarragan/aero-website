---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import SponsorRibbon from '../components/SponsorRibbon.astro';

const sections = [
	{
		num: '01',
		title: 'About Us',
		blurb:
			'Who we are, where we started at the University of Ottawa, and what drives every design decision we make.',
		cta: 'Meet the mission',
		href: '/about',
		img: '/images/site/wide-workshop.webp',
	},
	{
		num: '02',
		title: 'Meet the Team',
		blurb: 'The students behind the airframe — leads, members, and the disciplines that keep us flying.',
		cta: 'Meet the team',
		href: '/team',
		img: '/images/team/ana-j-barragan.webp',
	},
	{
		num: '03',
		title: 'Competition',
		blurb: 'SAE Aero Design: the categories we fly, and the criteria we are judged on.',
		cta: 'See the competition',
		href: '/competition',
		img: '/images/site/comp-2025-teams.webp',
	},
	{
		num: '04',
		title: 'Our Aircraft',
		blurb: 'Year over year airframes, stats, and the engineering behind each build.',
		cta: 'View the aircraft',
		href: '/aircraft',
		img: '/images/site/adv-2026-render-front.webp',
	},
	{
		num: '05',
		title: 'Gallery',
		blurb: 'Construction, testing, and competition day — in photos.',
		cta: 'Open the gallery',
		href: '/gallery',
		img: '/images/aircraft/2026-micro/kaden-being-happy-with-the-current-state-of-sg32c.jpg',
	},
	{
		num: '06',
		title: 'Contact Us',
		blurb: 'Want to fly with us? Reach out — we are always recruiting.',
		cta: 'Get in touch',
		href: '/contact',
		img: '/images/site/stem-at-night.webp',
	},
];

const sponsors = [
	{ name: 'DuPont', logo: 'dupont.svg', href: 'https://www.dupont.ca/' },
	{ name: 'HTS', logo: 'hts.svg', href: 'https://www.hts.com/' },
	{ name: 'CEED uOttawa', logo: 'ceed.svg', href: 'https://ceed-uottawa.ca/' },
	{ name: 'Engineering Endowment Fund', logo: 'eef.svg', href: 'https://www.uottawa.ca/faculty-engineering/student-experience/funding-student-initiatives' },
	{ name: 'Rhystone', logo: 'rhystone.svg', href: 'https://www.rhystone.com/' },
	{ name: 'T-Motor', logo: 'tmotor.svg', href: 'https://store.tmotor.com/' },
];
---

<Layout>
	<NavBar active="home" />

	<section class="relative flex min-h-[620px] items-end overflow-hidden">
		<div class="absolute inset-0 grayscale">
			<img src="/images/site/winter-team-photo.webp" alt="Team photo before a test-flight" class="h-full w-full object-cover" />
		</div>
		<div
			class="absolute inset-0"
			style="background:linear-gradient(180deg, rgba(32,30,29,.1), rgba(32,30,29,.88)), linear-gradient(100deg, rgba(78,15,10,.55), transparent 60%)"
		>
		</div>
		<div class="absolute right-5 top-5 z-10 h-4 w-4 bg-accent"></div>
		<div class="relative mx-auto w-full max-w-[1240px] px-6 pb-14 pt-18 text-[#f3f2f2] md:px-10">
			<h6 class="mb-3 text-accent-300">University of Ottawa</h6>
			<h1 class="mb-4.5 max-w-[16ch] text-[40px] leading-tight text-white sm:text-6xl lg:text-[76px]">
				Design. Build. Test. Fly.
			</h1>
			<p class="mb-7 max-w-[58ch] text-lg text-[#f3f2f2]/90">
				uOAeronautics is a uOttawa JMTS team that builds RC aircraft for the SAE Aero Design
				competition. This year, we are designing and building an aircraft for both the Advanced
				Class and the Micro Class.
			</p>
			<div class="flex flex-wrap gap-3.5">
				<a href="/team" class="btn btn-primary">Meet the Team</a>
				<a href="https://forms.cloud.microsoft/r/5zeg93ke8z" class="btn btn-secondary" style="border-color:rgba(243,242,242,.55);color:#fff"
					>Join Us</a
				>
			</div>
		</div>
	</section>

	{
		sections.map((item, i) => (
			<section class:list={['px-6 py-18 md:px-10', i % 2 === 0 ? 'bg-bg' : 'bg-surface']}>
				<div
					class:list={[
						'mx-auto flex max-w-[1240px] flex-wrap items-center gap-14',
						i % 2 === 0 ? 'flex-row' : 'flex-row-reverse',
					]}
				>
					<div class="grayscale min-w-[280px] flex-1 basis-[440px]">
						<img src={item.img} alt={item.title} class="aspect-4/3 w-full object-cover" />
					</div>
					<div class="min-w-[280px] flex-1 basis-[440px]">
						<div class="mb-0.5 flex items-center gap-2">
							<span class="h-2.5 w-2.5 flex-none bg-accent" />
							<h6 class="m-0 text-accent">{item.num}</h6>
						</div>
						<h2 class="mb-3.5">{item.title}</h2>
						<p class="mb-6 max-w-[52ch] text-base text-ink/60">{item.blurb}</p>
						<a href={item.href} class="btn btn-primary">
							{item.cta} &rarr;
						</a>
					</div>
				</div>
			</section>
		))
	}

	<section class="mx-auto max-w-[1240px] px-6 pb-14 pt-4 md:px-10">
		<h6 class="text-accent">Have a Look at What We've Done</h6>
		<h2 class="mb-7">Our aircraft, year over year</h2>
		<div class="grid grid-cols-[repeat(auto-fit,minmax(240px,1fr))] gap-6">
			<div class="card gap-3 p-5 shadow-sm">
				<img src="/images/site/adv-2026-render-front.webp" alt="Advanced 2026 — Starling" class="aspect-4/3 w-full object-cover" style="border-radius:5px" />
				<h3 class="m-0 text-lg">Advanced &mdash; 2026</h3>
				<a href="/competition" class="btn btn-secondary">Learn More</a>
			</div>
			<div class="card gap-3 p-5 shadow-sm">
				<img src="/images/site/micro-2026-sitting-on-snow.webp" alt="Micro 2026 — SG32C" class="aspect-4/3 w-full object-cover" style="border-radius:5px" />
				<h3 class="m-0 text-lg">Micro &mdash; 2026</h3>
				<a href="/competition" class="btn btn-secondary">Learn More</a>
			</div>
			<div class="card gap-3 p-5 shadow-sm">
				<img src="/images/site/micro-on-the-concrete.webp" alt="Micro 2025 — UOAN-M25" class="aspect-4/3 w-full object-cover" style="border-radius:5px" />
				<h3 class="m-0 text-lg">Micro &mdash; 2025</h3>
				<a href="/competition" class="btn btn-secondary">Learn More</a>
			</div>
			<div class="card gap-3 p-5 shadow-sm">
				<img src="/images/site/adv-gala.webp" alt="Advanced 2025 — Longshot" class="aspect-4/3 w-full object-cover" style="border-radius:5px" />
				<h3 class="m-0 text-lg">Advanced &mdash; 2025</h3>
				<a href="/competition" class="btn btn-secondary">Learn More</a>
			</div>
		</div>
	</section>

	<section class="bg-accent-900 px-6 py-16 text-[#f3f2f2] md:px-10">
		<div class="mx-auto flex max-w-[1240px] flex-wrap items-end justify-between gap-8">
			<div class="max-w-[56ch]">
				<h6 class="text-accent-300">Our Partners</h6>
				<h2 class="mb-3 text-white">Built with the support of our sponsors</h2>
				<p class="m-0 text-base text-[#f3f2f2]/80">
					Every airframe we fly is made possible by the companies and organizations who back our
					team. Interested in partnering with us?
				</p>
			</div>
			<a href="/partner" class="btn btn-secondary flex-none" style="border-color:rgba(243,242,242,.55);color:#fff"
				>Want to sponsor us? &rarr;</a
			>
		</div>
		<div class="mx-auto mt-8 flex max-w-[1240px] flex-wrap items-center gap-4">
			{
				sponsors.map((s) => (
					<a href={s.href} class="flex h-[64px] w-[144px] items-center justify-center bg-white p-3" title={s.name}>
						<img src={`/images/sponsors/${s.logo}`} alt={`${s.name} logo`} class="max-h-full max-w-full" />
					</a>
				))
			}
		</div>
	</section>

	<SponsorRibbon />
</Layout>
